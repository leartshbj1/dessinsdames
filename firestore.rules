rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /drawings/{drawingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogComments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
